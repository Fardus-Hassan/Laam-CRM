{
    "name": "@laam/source",
    "version": "0.0.0",
    "license": "MIT",
    "private": true,
    "scripts": {
        "dev": "nx run-many -t serve,dev -p api,web --parallel=2 --output-style=stream",
        "dev:web": "nx dev web -- -p 3000",
        "dev:api": "cross-env PORT=3333 nx serve api",
        "dev:worker": "nx serve worker",
        "build": "nx run-many -t build -p types,api,web,worker",
        "build:all": "nx run-many -t build",
        "typecheck": "nx run-many -t typecheck",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
        "db:push": "prisma db push --schema=apps/api/prisma/schema.prisma",
        "db:seed": "node apps/api/prisma/seed.mjs"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "next": "~16.1.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@nx/esbuild": "23.0.1",
        "@nx/js": "23.0.1",
        "@nx/nest": "^23.0.1",
        "@nx/next": "^23.0.1",
        "@nx/node": "^23.0.1",
        "@nx/react": "^23.0.1",
        "@nx/web": "23.0.1",
        "@nx/webpack": "^23.0.1",
        "@swc-node/register": "~1.11.1",
        "@swc/cli": "~0.8.0",
        "@swc/core": "~1.15.5",
        "@swc/helpers": "~0.5.18",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "cross-env": "^10.1.0",
        "esbuild": "0.27.7",
        "nx": "23.0.1",
        "prettier": "~3.6.2",
        "tslib": "^2.3.0",
        "typescript": "~5.9.2",
        "webpack": "^5.101.3",
        "webpack-cli": "^7.0.0",
        "webpack-dev-server": "^5.2.1"
    }
}